{
  "name": "@ethora/cli",
  "version": "1.2.0",
  "description": "CLI tool for the Ethora BNB Faucet",
  "license": "MIT",
  "bin": {
    "ethora-faucet": "./dist/cli.js"
  },
  "type": "module",
  "scripts": {
    "build": "tsup src/cli.ts --format esm --banner.js '#!/usr/bin/env node' --dts --clean",
    "dev": "tsx src/cli.ts",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@ethora/faucet-sdk": "workspace:*",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "ora": "^8.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.25",
    "rimraf": "^5.0.5",
    "tsup": "^8.0.2",
    "tsx": "^4.7.1",
    "typescript": "^5.4.3"
  },
  "keywords": ["bnb", "faucet", "testnet", "cli"]
}

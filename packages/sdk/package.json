{
  "name": "@ethora/faucet-sdk",
  "version": "1.2.0",
  "description": "TypeScript SDK for the Ethora BNB Faucet API",
  "license": "MIT",
  "author": "Ethora Labs <dev@ethora.io>",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^1.4.0",
    "msw": "^2.2.13",
    "rimraf": "^5.0.5",
    "tsup": "^8.0.2",
    "typescript": "^5.4.3",
    "vitest": "^1.4.0"
  },
  "keywords": ["bnb", "bsc", "faucet", "testnet", "ethereum", "web3", "sdk"]
}

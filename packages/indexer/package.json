{
  "name": "@ethora/indexer",
  "version": "1.2.0",
  "description": "On-chain event indexer for the Ethora BNB Faucet",
  "license": "MIT",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "db:migrate": "tsx src/db/migrate.ts",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "ethers": "^6.11.1",
    "pg": "^8.11.3"
  },
  "devDependencies": {
    "@types/node": "^20.11.25",
    "@types/pg": "^8.11.2",
    "rimraf": "^5.0.5",
    "tsx": "^4.7.1",
    "typescript": "^5.4.3"
  }
}
